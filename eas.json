{
  "cli": {
    "version": ">= 5.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": { "SENTRY_DISABLE_AUTO_UPLOAD": "true" }
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "android": { "buildType": "apk" },
      "ios": { "simulator": true },
      "env": { "SENTRY_DISABLE_AUTO_UPLOAD": "true" }
    },
    "production": {
      "channel": "production",
      "autoIncrement": true,
      "env": { "SENTRY_DISABLE_AUTO_UPLOAD": "true" }
    }
  },
  "submit": {
    "production": {}
  }
}
