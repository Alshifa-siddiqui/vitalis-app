# Copy this file to `.env` and fill in your Supabase project values.
# Supabase dashboard → Project Settings → API.
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_PUBLIC_KEY

# Optional: crash & error monitoring (Sentry). Leave blank to disable.
# Create a free React Native project at sentry.io → copy its DSN here.
EXPO_PUBLIC_SENTRY_DSN=
